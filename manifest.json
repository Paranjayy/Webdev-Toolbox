{
  "manifest_version": 3,
  "name": "WEBDEV TOOLBOX",
  "version": "1.3.2",
  "description": "High-fidelity intelligence & design toolkit for elite web development.",
  "permissions": [
    "management",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Dev Vault",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
